# Copy this file to .env.local and fill in your values

# JIRA - for GSRR SLO compliance, support tickets, and other JIRA measures
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_BASE_URL=https://your-domain.atlassian.net
# Optional: limit support tickets to a project (e.g. MOB, ENG)
# JIRA_SUPPORT_PROJECT=MOB

# Jellyfish - for KTLO, lead time, company metrics
JELLYFISH_API_TOKEN=your_jellyfish_api_token

# Jellyfish DevEx - for developer survey data (API not yet publicly documented)
# DEVEX_API_TOKEN=your_devex_api_token

# Incident.io - incidents, MTTR, reliability metrics
INCIDENT_IO_API_KEY=your_incident_io_api_key
# Optional: link to Incident.io incidents list for validation (default: https://app.incident.io/iterable/incidents)
# INCIDENT_IO_INCIDENTS_URL=https://app.incident.io/iterable/incidents
# ES/ingestion SEV1/2 reduction measure (Root cause=Load, Theme=Excessive Journey/Bulk Updates)
# ES_INGESTION_BASELINE=12
# ES_INGESTION_TARGET_REDUCTION=50
# ES negative-margin measure (Root cause=Load, ES/user-update related)
# ES_NEGATIVE_MARGIN_BASELINE=50
# ES_NEGATIVE_MARGIN_TARGET_REDUCTION=20

# Attrition - Engineering attrition % (target: <12% annualized)
# Hardcoded in v2mom-data.ts (6/135). Override via env for live data:
# Option 1a: Departures + headcount
# ATTRITION_DEPARTURES=6
# ATTRITION_HEADCOUNT=135
# Option 1b: Or set percent directly
# ATTRITION_PERCENT=8.5
# Option 2: Private Google Sheet (recommended) - service account, sheet stays private
# 1. Create service account: Google Cloud Console → APIs & Services → Credentials → Create Service Account
# 2. Enable Google Sheets API for the project
# 3. Create a key (JSON), download it
# 4. Share your sheet with the service account email (Viewer access)
# ATTRITION_SHEET_ID=1cBI_YRtuYqtNPzLXn-pK7IPmYpNYEDmi8RV-n3awM2E
# ATTRITION_HEADCOUNT=150
# ATTRITION_MONTHS=12
# ATTRITION_SHEET_RANGE=Sheet1!A:Z
# Credentials - use one of:
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=<base64 of your JSON key>
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # minified, single line

# Sigma - export dashboard/workbook data (OAuth client credentials)
# Workspace: https://app.sigmacomputing.com/iterable
# Generate credentials: Sigma Admin > Developer Access (NOT API connectors)
SIGMA_CLIENT_ID=your_sigma_client_id
SIGMA_CLIENT_SECRET=your_sigma_client_secret
# If auth fails, your cloud may need a different base URL (e.g. https://aws-api.sigmacomputing.com)
# Check: Sigma > Administration > Account for your API URL
# SIGMA_API_BASE_URL=https://api.sigmacomputing.com
# Optional: for "View in Sigma" links (defaults to iterable workspace)
# SIGMA_APP_URL=https://app.sigmacomputing.com/iterable
# ES negative-margin: User Updates to User Profiles - Per Org workbook
# Workbook: https://app.sigmacomputing.com/iterable/workbook/Engineering-User-Updates-4HbnLZjgP0WGf0pkmPmBYW
# SIGMA_ES_NEGATIVE_MARGIN_WORKBOOK_ID=4HbnLZjgP0WGf0pkmPmBYW
# SIGMA_ES_NEGATIVE_MARGIN_ELEMENT_ID=INJ4aYREFO   # nodeId from table URL (?:nodeId=...)
# Date filter - Control ID from Sigma workbook (element props)
# SIGMA_ES_NEGATIVE_MARGIN_DATE_CONTROL_ID=Date
# SIGMA_ES_NEGATIVE_MARGIN_BASELINE_DATE=2026-01-31   # FY26 baseline date
# SIGMA_ES_NEGATIVE_MARGIN_AS_OF_DAYS=2               # Current = N days ago
# ES_NEGATIVE_MARGIN_BASELINE=21
# ES_NEGATIVE_MARGIN_BASELINE_OVERAGE=11123   # FY26 daily COGS overage $ (for % reduction calc)
# ES_NEGATIVE_MARGIN_TARGET_REDUCTION=50
