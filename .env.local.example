# Copy this file to .env.local and fill in your values
# Get these from your Supabase project: https://supabase.com/dashboard

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# JIRA - for GSRR SLO compliance and other JIRA measures
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_BASE_URL=https://your-domain.atlassian.net

# Jellyfish - for KTLO allocations (Lever under Allocations)
JELLYFISH_API_TOKEN=your_jellyfish_api_token
